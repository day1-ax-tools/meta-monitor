{
  "version": 1,
  "enabled": true,
  "activation": "explicit",
  "provider": "openai",
  "model": "gpt-5-codex",
  "effort": "medium",
  "language": {
    "source": "main-session-input",
    "current": "ko",
    "fallback": "en"
  },
  "contextWindowTokens": 200000,
  "contextSoftLimitRatio": 0.7,
  "fastMode": false,
  "questionTransport": {
    "type": "local-http-bridge",
    "endpoint": "/api/questions",
    "queue": "meta-guardian/questions.jsonl"
  },
  "answerWorker": {
    "type": "codex-exec-read-only",
    "script": "meta-guardian/guardian-worker.mjs",
    "output": "meta-guardian/guardian-advice.md",
    "state": "meta-guardian/guardian-state.json",
    "runtimeModel": "codex-cli-default"
  },
  "guardianInput": {
    "schema": "meta-guardian/guardian-input.schema.json",
    "prompt": "meta-guardian/guardian-prompt.md",
    "events": "meta-guardian/main-session-events.jsonl",
    "latest": "meta-guardian/guardian-input.latest.json",
    "mode": "observe-main-session-first"
  },
  "mainSession": {
    "provider": "openai",
    "model": "codex-cli-default",
    "sessionId": "main-session",
    "description": "Visible main AI CLI session"
  },
  "design": {
    "source": "main-session-provider",
    "provider": "openai",
    "reference": "DESIGN.md"
  },
  "writeScope": ["meta-guardian/**"],
  "readScope": ["**"],
  "guardianBoard": "meta-guardian/guardian-board.html",
  "sessionData": "meta-guardian/session-data.jsonl",
  "handoff": "meta-guardian/session-handoff.md"
}
